+#include <cerrno>
+#include <cstdlib>
@@ -20 +23 @@
-#include <string>
+#include <limits>
@@ -21,0 +25 @@
+#include <string>
@@ -37,0 +42,21 @@ namespace actions {
+namespace {
+
+int parseIntegerOrZero(const std::string& input) {
+    if (input.empty()) {
+        return 0;
+    }
+
+    errno = 0;
+    char *end = nullptr;
+    const long parsed = std::strtol(input.c_str(), &end, 10);
+    if (end == input.c_str() || errno == ERANGE ||
+        parsed < std::numeric_limits<int>::min() ||
+        parsed > std::numeric_limits<int>::max()) {
+        return 0;
+    }
+    return static_cast<int>(parsed);
+}
+
+}  // namespace
+
+
