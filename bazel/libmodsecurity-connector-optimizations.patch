+
+        std::vector<const VariableValue *> values;
+        try {
+            RuleWithOperator *rr = dynamic_cast<RuleWithOperator *>(rule);
+            m_variable->evaluate(t, rr, &values);
+            if (values.empty()) {
+                value = 0;
+            } else {
+                value = parseIntegerOrZero(values[0]->getValue());
+            }
+        } catch (...) {
+            value = 0;
+        }
+        for (const VariableValue *item : values) {
+            delete item;
+        }
