# Test-only ModSecurity configuration for the complete pinned OWASP CRS regression corpus.
# Audit logging is intentionally limited to the message section so go-ftw can assert exact rule
# IDs without recording request or response bodies.
SecRuleEngine DetectionOnly
SecRequestBodyAccess On
SecRequestBodyLimit 16777216
SecRequestBodyNoFilesLimit 16777216
SecRequestBodyLimitAction Reject
SecRequestBodyJsonDepthLimit 512
SecArgumentsLimit 1000

SecRule REQUEST_HEADERS:Content-Type "^(?:application(?:/soap\\+|/)|text/)xml" \
    "id:200000,phase:1,t:none,t:lowercase,pass,nolog,ctl:requestBodyProcessor=XML"
SecRule REQUEST_HEADERS:Content-Type "^application/(?:[a-z0-9.-]+\\+)?json(?:\\s*;|$)" \
    "id:200001,phase:1,t:none,t:lowercase,pass,nolog,ctl:requestBodyProcessor=JSON"

SecResponseBodyAccess On
SecResponseBodyMimeType text/plain text/html text/xml application/xml application/json
SecResponseBodyLimit 1048576
SecResponseBodyLimitAction Reject

SecAuditEngine On
SecAuditLogParts AHZ
SecAuditLogType Serial
SecAuditLog __AUDIT_LOG__
SecUnicodeMapFile __UNICODE_MAPPING__ 20127
SecStatusEngine Off
SecXmlExternalEntity Off

# Match the variables documented by the pinned CRS regression suite. DetectionOnly keeps tests
# observational: rule matches are asserted from the audit log and do not block the test backend.
SecAction \
    "id:900005,phase:1,nolog,pass,ctl:ruleEngine=DetectionOnly,ctl:ruleRemoveById=910000,setvar:tx.blocking_paranoia_level=4,setvar:tx.detection_paranoia_level=4,setvar:tx.crs_validate_utf8_encoding=1,setvar:tx.arg_name_length=100,setvar:tx.arg_length=400,setvar:tx.total_arg_length=64000,setvar:tx.max_num_args=255,setvar:tx.max_file_size=64100,setvar:tx.combined_file_sizes=65535"

Include __CRS_SETUP__
__CRS_RULE_INCLUDES__

# go-ftw brackets each test with marker requests. Disable the CRS rules for marker transactions so
# only the test request contributes rule matches between the two markers.
SecRule REQUEST_HEADERS:X-CRS-Test "@rx ^.*$" \
    "id:999999,phase:1,pass,log,msg:'X-CRS-Test %{MATCHED_VAR}',ctl:ruleRemoveById=1-999999"
